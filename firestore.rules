rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // Role Helper Functions
    //
    // All role checks use request.auth.token.role (custom claims from the JWT).
    // This avoids extra Firestore reads on every rule evaluation and prevents
    // role escalation via Firestore document manipulation.
    //
    // Custom claims are set by Cloud Functions (inviteUser, setUserRole,
    // migrateExistingUsers) and are the single source of truth.
    // ─────────────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns the role from JWT custom claims.
    // Null for legacy accounts without claims (treated as member).
    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Global admin override — admins have full read/write access to everything
    // ─────────────────────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Users collection (company profiles)
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Public can read user profiles (for company listings on homepage)
      allow read: if true;

      // Users can create their own profile during registration
      allow create: if isOwner(userId);

      // Users can update their own profile, BUT cannot self-modify the 'role' field.
      // Role changes must go through the setUserRole Cloud Function (admin only).
      allow update: if isOwner(userId) &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role == resource.data.role
        );

      // Admin can delete user records (hard delete goes through deleteUser Cloud Function)
      allow delete: if isAdmin();

      // Lawyer reviews subcollection (public read — shown on lawyer profiles)
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if false; // All writes via Cloud Functions (submitLawyerReview)
      }

      // Security subcollection (backup codes for 2FA)
      match /security/{docId} {
        allow read, write: if isOwner(userId);
      }

      // User notifications subcollection (private)
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated() && (
          isAdmin() ||
          (
            request.resource.data.type in ['message', 'quote', 'system', 'admin',
              'new_message', 'conversation_created', 'quote_received',
              'quote_accepted', 'quote_rejected', 'new_user_approval',
              'deal', 'legal', 'announcement', 'rfq_created',
              'product_upload_request'] &&
            request.resource.data.keys().hasAll(['type', 'title', 'isRead']) &&
            request.resource.data.isRead == false &&
            request.auth.uid != userId
          )
        );
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Invites collection (admin-only)
    // Invite documents are created by the inviteUser Cloud Function.
    // TTL: configure Firebase Console TTL policy on Field=expireAt
    // ─────────────────────────────────────────────────────────────────────────

    match /invites/{inviteId} {
      // Invited user can read their own invite (needed during onboarding to get email)
      allow read: if isAdmin() || (isAuthenticated() && isOwner(inviteId));
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Products collection (public read for homepage/listings)
    // ─────────────────────────────────────────────────────────────────────────

    match /products/{productId} {
      // Public can view products (homepage, search)
      allow read: if true;
      // Only authenticated users can create/edit their own products
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Requests/RFQs collection (public read for homepage/listings)
    // ─────────────────────────────────────────────────────────────────────────

    match /requests/{requestId} {
      // Public can view RFQs
      allow read: if true;
      // Only authenticated users can create/edit their own requests
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Quotes subcollection (offers for RFQs)
      match /quotes/{quoteId} {
        // Helper: Check if user is the RFQ owner (document read is acceptable here —
        // it's scoped to a specific subcollection, not for role checking)
        function isRequestOwner() {
          return request.auth.uid == get(/databases/$(database)/documents/requests/$(requestId)).data.userId;
        }

        // READ: Only request owner or admin can view quotes
        allow read: if isAuthenticated() && (isRequestOwner() || isAdmin());

        // CREATE: Any authenticated user can submit a quote
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

        // UPDATE: Only request owner can update quote status (accept/reject)
        allow update: if isAuthenticated() && (isRequestOwner() || isAdmin());

        // DELETE: Only admin
        allow delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Categories collection (public read for dropdowns/filters)
    // ─────────────────────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Fairs collection (public read)
    // ─────────────────────────────────────────────────────────────────────────

    match /fairs/{fairId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // News collection (public read)
    // ─────────────────────────────────────────────────────────────────────────

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Conversations collection (private — only participants)
    // ─────────────────────────────────────────────────────────────────────────

    match /conversations/{conversationId} {
      function isParticipant() {
        return isAuthenticated() && request.auth.uid in resource.data.participants;
      }

      function willBeParticipant() {
        return isAuthenticated() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      allow create: if isAuthenticated() && willBeParticipant();
      allow update: if isParticipant() || isAdmin();
      allow delete: if isAdmin();

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin()
        );
        allow create: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid
        );
        // Allow update if user is the sender OR a participant (for marking as read)
        allow update: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants ||
          isAdmin()
        );
        // Sender can delete own message, admin can delete any
        allow delete: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Deals collection (private — only deal participants)
    //
    // All writes (create, update, delete) go through Cloud Functions using the
    // Admin SDK, which bypasses these rules. Rules only govern client reads.
    // ─────────────────────────────────────────────────────────────────────────

    match /deals/{dealId} {
      // isDealParticipant is defined locally (not top-level) because it reads
      // resource.data, which is document-context-specific.
      function isDealParticipant() {
        return request.auth.uid == resource.data.buyerId ||
               request.auth.uid == resource.data.sellerId;
      }

      // Participants, admins, and assigned lawyers can read the deal document in real-time.
      // Lawyers are stored in the lawyerIds array on the deal doc (Phase 5).
      // get('lawyerIds', []) provides a safe default for older deals that don't have this field.
      allow read: if isAuthenticated() && (isDealParticipant() || isAdmin() || request.auth.uid in resource.data.get('lawyerIds', []));

      // All creates/updates/deletes go through Cloud Functions (Admin SDK bypasses rules)
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      // Offers subcollection — same participant-only read access
      // NOTE: resource.data inside this subcollection refers to the OFFER document,
      // not the parent deal. isDealParticipant() reads resource.data.buyerId/sellerId
      // which don't exist on offers. Use get() to read the parent deal document instead.
      match /offers/{offerId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/deals/$(dealId)).data.buyerId ||
          request.auth.uid == get(/databases/$(database)/documents/deals/$(dealId)).data.sellerId
        );
        allow write: if false; // All writes via Cloud Functions
      }

      // Contract subcollection — participant-only read, all writes via Cloud Functions
      // The contract document lives at deals/{dealId}/contract/main and is auto-generated
      // by the onDealAccepted Cloud Function when a deal transitions to 'accepted' status.
      match /contract/{contractDoc} {
        allow read: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/deals/$(dealId)).data.buyerId ||
          request.auth.uid == get(/databases/$(database)/documents/deals/$(dealId)).data.sellerId
        );
        allow write: if false; // All writes via Cloud Functions (Admin SDK)
      }

      // Shipment tracking subcollection (Phase 6)
      // Read: any authenticated user (parent deal is already access-controlled).
      match /shipmentTracking/{updateId} {
        allow read: if isAuthenticated();
        allow write: if false; // All writes via Cloud Functions (submitShipmentUpdate, confirmInsuranceCoverage)
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Quote Requests collection (Phase 4 — insurance/logistics provider portals)
    //
    // Created by broadcastQuoteRequests Cloud Function (Admin SDK).
    // All writes go through Cloud Functions — client writes denied.
    // Read access: assigned provider, buyer, seller, or admin.
    //
    // providerQuotes subcollection uses denormalized buyerId/sellerId on the
    // quote doc itself — avoids get() calls per Pitfall 4 (no extra reads in rules).
    // ─────────────────────────────────────────────────────────────────────────

    match /quoteRequests/{requestId} {
      // Assigned provider, buyer, seller, or admin can read.
      // Provider queries use where('providerUid', '==', uid) → satisfies providerUid check.
      // Buyer/seller queries use where('participants', 'array-contains', uid) → satisfies in check.
      allow read: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid == resource.data.providerUid ||
        request.auth.uid in resource.data.participants
      );
      // All writes via Cloud Functions (Admin SDK bypasses rules)
      allow write: if false;

      // providerQuotes subcollection
      match /providerQuotes/{quoteId} {
        allow read: if isAuthenticated();
        // All writes via Cloud Functions (Admin SDK bypasses rules)
        allow write: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Legal Engagements collection (Phase 5 — legal consulting)
    //
    // Created and updated exclusively by Cloud Functions (Admin SDK).
    // Client reads are gated on participants array-contains for complete isolation:
    //   only clientId and lawyerId can access the engagement and its subcollections.
    // Opposing deal parties have zero access.
    //
    // Messages: participants can create while status == 'active'; immutable after creation.
    // Contract drafts: participants can upload; immutable after upload.
    // Risk items: lawyerId only can create/update; immutable for client.
    // ─────────────────────────────────────────────────────────────────────────

    match /legalEngagements/{engagementId} {
      function isEngagementParticipant() {
        return request.auth.uid in resource.data.participants;
      }

      allow read: if isAuthenticated() && isEngagementParticipant();
      allow create: if false;  // Cloud Functions only
      allow update: if false;  // Cloud Functions only
      allow delete: if false;

      match /legalMessages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.participants &&
          get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.status == 'active' &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }

      match /contractDrafts/{draftId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.participants &&
          get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.status == 'active';
        allow update, delete: if false;
      }

      match /riskItems/{riskId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.participants;
        allow create, update: if isAuthenticated() &&
          request.auth.uid == get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.lawyerId &&
          get(/databases/$(database)/documents/legalEngagements/$(engagementId)).data.status == 'active';
        allow delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Newsletter collection (public create)
    // ─────────────────────────────────────────────────────────────────────────

    match /newsletter/{subscriberId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Cold email unsubscribes — written only by server (Admin SDK bypasses rules).
    // Clients cannot read or write directly.
    match /unsubscribes/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Ad Inquiries (public advertising pricing page)
    //
    // Anyone (auth or not) can submit an inquiry from /pricing/inquire; each
    // create is validated against a strict shape + a naive rate limit that
    // caps `createdAt` to a very tight server-time band, so a spamming client
    // can't pre-stamp future timestamps. Admins can list, read, and mark as
    // handled via the /admin dashboard. Update is admin-only (status changes
    // + notes). Delete is admin-only for GDPR cleanup.
    // ─────────────────────────────────────────────────────────────────────────

    match /adInquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
                       'company', 'website', 'contactName', 'email',
                       'package', 'campaignMonth', 'campaignWeek', 'brief',
                       'status', 'createdAt'
                     ])
                   && request.resource.data.company is string
                   && request.resource.data.company.size() > 0
                   && request.resource.data.company.size() <= 200
                   && request.resource.data.website is string
                   && request.resource.data.website.size() <= 500
                   && request.resource.data.contactName is string
                   && request.resource.data.contactName.size() > 0
                   && request.resource.data.contactName.size() <= 200
                   && request.resource.data.email is string
                   && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
                   && request.resource.data.email.size() <= 254
                   && request.resource.data.package is string
                   && request.resource.data.package.size() <= 100
                   && request.resource.data.campaignMonth is string
                   && request.resource.data.campaignMonth.size() <= 30
                   && request.resource.data.campaignWeek is string
                   && request.resource.data.campaignWeek.size() <= 30
                   && request.resource.data.brief is string
                   && request.resource.data.brief.size() <= 2000
                   && request.resource.data.status == 'new'
                   && request.resource.data.createdAt == request.time;
      allow read, list: if isAdmin();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'handledAt', 'handledBy', 'adminNote']);
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Product Upload Requests collection (Plan 17-04)
    //
    // Users submit a request for admin-assisted product upload.
    // Authenticated user can create their own request (uid must match).
    // Admin can read and update all requests.
    // ─────────────────────────────────────────────────────────────────────────

    match /productUploadRequests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated() && (
        isAdmin() || resource.data.uid == request.auth.uid
      );
      allow update: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Announcements collection (Plan 12-05)
    //
    // Admin-only read/write. Announcements are historical records — delete is denied.
    // All delivery (in-app, push, email) is performed server-side via Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────────

    match /announcements/{announcementId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}

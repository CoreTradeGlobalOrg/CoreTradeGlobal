rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // Role Helper Functions
    //
    // All role checks use request.auth.token.role (custom claims from the JWT).
    // This avoids extra Firestore reads on every rule evaluation and prevents
    // role escalation via Firestore document manipulation.
    //
    // Custom claims are set by Cloud Functions (inviteUser, setUserRole,
    // migrateExistingUsers) and are the single source of truth.
    // ─────────────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns the role from JWT custom claims.
    // Null for legacy accounts without claims (treated as member).
    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    // Null/missing role fallback: existing member accounts without custom claims
    // are treated as members per the migration strategy in CONTEXT.md.
    function isMember() {
      return isAuthenticated() && (userRole() == 'member' || userRole() == null);
    }

    function isProvider() {
      return isAuthenticated() &&
        (userRole() == 'logistics_provider' || userRole() == 'insurance_provider');
    }

    function isInsuranceProvider() {
      return isAuthenticated() && userRole() == 'insurance_provider';
    }

    function isLogisticsProvider() {
      return isAuthenticated() && userRole() == 'logistics_provider';
    }

    function isLawyer() {
      return isAuthenticated() && userRole() == 'lawyer';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Global admin override — admins have full read/write access to everything
    // ─────────────────────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Users collection (company profiles)
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Any authenticated user can read user profiles (for company listings, messaging)
      allow read: if isAuthenticated();

      // Users can create their own profile during registration
      allow create: if isOwner(userId);

      // Users can update their own profile, BUT cannot self-modify the 'role' field.
      // Role changes must go through the setUserRole Cloud Function (admin only).
      allow update: if isOwner(userId) &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role == resource.data.role
        );

      // Admin can delete user records (hard delete goes through deleteUser Cloud Function)
      allow delete: if isAdmin();

      // User notifications subcollection (private)
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated() && (
          isAdmin() ||
          (
            request.resource.data.type in ['message', 'quote', 'system', 'admin',
              'new_message', 'conversation_created', 'quote_received',
              'quote_accepted', 'quote_rejected', 'new_user_approval'] &&
            request.resource.data.keys().hasAll(['type', 'title', 'isRead']) &&
            request.resource.data.isRead == false &&
            request.auth.uid != userId
          )
        );
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Invites collection (admin-only)
    // Invite documents are created by the inviteUser Cloud Function.
    // TTL: configure Firebase Console TTL policy on Field=expireAt
    // ─────────────────────────────────────────────────────────────────────────

    match /invites/{inviteId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Products collection (public read for homepage/listings)
    // ─────────────────────────────────────────────────────────────────────────

    match /products/{productId} {
      // Public can view products (homepage, search)
      allow read: if true;
      // Only authenticated users can create/edit their own products
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Requests/RFQs collection (public read for homepage/listings)
    // ─────────────────────────────────────────────────────────────────────────

    match /requests/{requestId} {
      // Public can view RFQs
      allow read: if true;
      // Only authenticated users can create/edit their own requests
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Quotes subcollection (offers for RFQs)
      match /quotes/{quoteId} {
        // Helper: Check if user is the RFQ owner (document read is acceptable here —
        // it's scoped to a specific subcollection, not for role checking)
        function isRequestOwner() {
          return request.auth.uid == get(/databases/$(database)/documents/requests/$(requestId)).data.userId;
        }

        // READ: Only request owner or admin can view quotes
        allow read: if isAuthenticated() && (isRequestOwner() || isAdmin());

        // CREATE: Any authenticated user can submit a quote
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

        // UPDATE: Only request owner can update quote status (accept/reject)
        allow update: if isAuthenticated() && (isRequestOwner() || isAdmin());

        // DELETE: Only admin
        allow delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Categories collection (public read for dropdowns/filters)
    // ─────────────────────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Fairs collection (public read)
    // ─────────────────────────────────────────────────────────────────────────

    match /fairs/{fairId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // News collection (public read)
    // ─────────────────────────────────────────────────────────────────────────

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Conversations collection (private — only participants)
    // ─────────────────────────────────────────────────────────────────────────

    match /conversations/{conversationId} {
      function isParticipant() {
        return isAuthenticated() && request.auth.uid in resource.data.participants;
      }

      function willBeParticipant() {
        return isAuthenticated() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      allow create: if isAuthenticated() && willBeParticipant();
      allow update: if isParticipant() || isAdmin();
      allow delete: if isAdmin();

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin()
        );
        allow create: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid
        );
        // Allow update if user is the sender OR a participant (for marking as read)
        allow update: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Deals collection (private — only deal participants)
    //
    // All writes (create, update, delete) go through Cloud Functions using the
    // Admin SDK, which bypasses these rules. Rules only govern client reads.
    // ─────────────────────────────────────────────────────────────────────────

    match /deals/{dealId} {
      // isDealParticipant is defined locally (not top-level) because it reads
      // resource.data, which is document-context-specific.
      function isDealParticipant() {
        return request.auth.uid == resource.data.buyerId ||
               request.auth.uid == resource.data.sellerId;
      }

      // Participants and admins can read the deal document in real-time
      allow read: if isAuthenticated() && (isDealParticipant() || isAdmin());

      // All creates/updates/deletes go through Cloud Functions (Admin SDK bypasses rules)
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      // Offers subcollection — same participant-only read access
      match /offers/{offerId} {
        allow read: if isAuthenticated() && isDealParticipant();
        allow write: if false; // All writes via Cloud Functions
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Newsletter collection (public create)
    // ─────────────────────────────────────────────────────────────────────────

    match /newsletter/{subscriberId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
